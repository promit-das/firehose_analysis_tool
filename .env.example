# Core runtime
DATABASE_PATH=data/firehose.duckdb
REPORT_OUTPUT_DIR=output/runs
DEFAULT_APP_ID=
DEFAULT_TENANT_ID=
DEFAULT_DELAY_BREACH_MS=30000

# LLM runtime
LLM_PROVIDER=circuit
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://chat-ai.cisco.com/openai
LLM_TEMPERATURE=0
LLM_REQUIRED_ON_STARTUP=1

# Provider API keys (fill the one matching LLM_PROVIDER)
CIRCUIT_API_KEY=
CIRCUIT_APP_KEY=
# CIRCUIT OAuth fallback (optional alternative to CIRCUIT_API_KEY)
CIRCUIT_API_CLIENT_ID=
CIRCUIT_API_CLIENT_SECRET=
CIRCUIT_API_URL=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
ANTHROPIC_API_KEY=
